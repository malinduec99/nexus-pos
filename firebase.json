{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "platform",
      "public": "dist",
      "cleanUrls": true,
      "trailingSlash": false,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [],
      "rewrites": [
        {
          "source": "/admin/**",
          "destination": "/admin.html"
        },
        {
          "source": "/track/**",
          "destination": "/track.html"
        },
        {
          "source": "/login",
          "destination": "/login.html"
        },
        {
          "source": "/**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "portal",
      "public": "pos-portal",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    }
  ],
  "headers": [
    {
      "source": "/updates/latest.yml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/**/*.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}