rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- AUTH HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Try to get metadata from employees OR customers
    function getUserMetadata() {
      let isEmployee = exists(/databases/$(database)/documents/employees/$(request.auth.uid));
      return isEmployee 
        ? get(/databases/$(database)/documents/employees/$(request.auth.uid)).data 
        : get(/databases/$(database)/documents/customers/$(request.auth.uid)).data;
    }

    function getRole() {
      let data = getUserMetadata();
      return data.role_access != null ? data.role_access : 'Customer';
    }

    function getUserShopId() {
      return getUserMetadata().shop_id;
    }

    // --- PERMISSION CHECKS ---

    function isSuperAdmin() {
      return isAuthenticated() && getRole() == 'SuperAdmin';
    }

    function isOwner(shopId) {
      let role = getRole();
      return isAuthenticated() && (role == 'Owner' || role == 'SuperAdmin') && (shopId == getUserShopId() || role == 'SuperAdmin');
    }

    function isTenantResource(resourceShopId) {
      return isAuthenticated() && (resourceShopId == getUserShopId() || isSuperAdmin());
    }

    // --- COLLECTION RULES ---

    match /stores/{store} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /employees/{employee} {
      allow read: if isAuthenticated() && (request.auth.uid == employee || isOwner(resource.data.shop_id));
      allow write: if isSuperAdmin() || (isOwner(request.resource.data.shop_id));
    }

    match /customers/{customer} {
      allow read: if isAuthenticated() && (request.auth.uid == customer || isOwner(resource.data.shop_id));
      allow write: if true; // Allow registration
    }

    match /{collectionName}/{docId} {
      allow read, write: if isAuthenticated() && (
        isSuperAdmin() || 
        (request.resource != null && isTenantResource(request.resource.data.shop_id)) ||
        (resource != null && isTenantResource(resource.data.shop_id))
      );
    }
  }
}
